{
  "name": "slidev-project-template",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "node scripts/dev-site.mjs",
    "preview": "vite preview --host 0.0.0.0 --outDir dist --open",
    "build": "node scripts/build-site.mjs",
    "export": "node scripts/export-deck.mjs",
    "fmt": "prettier --write .",
