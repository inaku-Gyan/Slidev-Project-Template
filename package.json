    "skills:list": "skills list",
    "skills:update": "skills update -p -y"
  },
  "devDependencies": {
    "@slidev/cli": "52.15.2",
    "@slidev/theme-default": "^0.25.0",
    "prettier": "^3.8.4",
    "prettier-plugin-slidev": "^1.0.5",
    "skills": "1.5.11",
    "slidev-theme-dracula": "^0.2.0",
    "yaml": "^2.9.0"
  }
}
